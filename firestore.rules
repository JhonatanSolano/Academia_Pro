rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Sub-collections (completions, etc.)
      match /{subcol}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Programs / Units / Topics / Contents (public read) ──
    match /programs/{docId} {
      allow read: if true;
      allow write: if false; // admin SDK only
    }
    match /units/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /topics/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /contents/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Events (metrics) ──
    // Any authenticated user can write their own events.
    // Only admins (via Admin SDK / server) should read.
    match /events/{eventId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read: if false; // read via Admin SDK or admin queries
    }
  }
}
